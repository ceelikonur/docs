{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Brain API",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      { "label": "Dashboard", "href": "https://brainapi.dev/dashboard" }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started Free",
      "href": "https://brainapi.dev/dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Fundamentals",
            "pages": [
              "fundamentals/mcp-integrations",
              "fundamentals/a2a-protocol"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/sap"
            ]
          },
          {
            "group": "Security",
            "pages": ["security/dlp-engine"]
          },
          {
            "group": "Use Cases",
            "pages": ["use-cases/sap-operations"]
          },
          {
            "group": "Resources",
            "pages": ["resources/changelog", "resources/roadmap"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Authentication",
            "pages": ["api-reference/authentication"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/ceelikonur/brain-api-demo",
          "icon": "github"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ceelikonur/brain-api-demo"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt"]
  }
}
